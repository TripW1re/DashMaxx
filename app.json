{
  "expo": {
    "name": "DashMaxx",
    "slug": "dashmaxx",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#0a0e1a"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.dashmaxx.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "DashMaxx uses your location to show nearby zones and plan optimal delivery routes.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "DashMaxx uses your location to show nearby zones and plan optimal delivery routes."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0a0e1a"
      },
      "package": "com.dashmaxx.app",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ]
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "DashMaxx uses your location to show nearby zones and plan optimal delivery routes.",
          "locationWhenInUsePermission": "DashMaxx uses your location to show nearby zones and plan optimal delivery routes."
        }
      ],
      "expo-asset",
      "expo-font",
      "expo-sharing",
      "expo-splash-screen",
      "expo-status-bar"
    ],
    "extra": {
      "firebaseApiKey": "AIzaSyCC3E0-49QO7zIRFqLidxnYpzRu8kuIB3Q",
      "firebaseAuthDomain": "dashmaxx-b61ed.firebaseapp.com",
      "firebaseProjectId": "dashmaxx-b61ed",
      "firebaseStorageBucket": "dashmaxx-b61ed.firebasestorage.app",
      "firebaseMessagingSenderId": "267996774709",
      "firebaseAppId": "1:267996774709:web:411ff6cbaa74451ebdcc7c"
    }
  }
}
