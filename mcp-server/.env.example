# DoorDash Auth Token
# Get this by logging into dasher.doordash.com → DevTools → Network →
# find api.doordash.com request → copy Authorization: Bearer <token>
DD_AUTH_TOKEN=

# Server config
PORT=3100
SYNC_INTERVAL_MINUTES=5

# Firebase (optional - in-memory cache used if not set)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
