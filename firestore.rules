rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // User data — only the authenticated user can access their own
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      match /shifts/{shiftId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      match /predictions/{zoneId} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow write: if false; // Only Cloud Functions write predictions
      }
    }

    // Zone data — public read, admin write
    match /zones/{zoneId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.isAdmin == true;
    }

    // Social posts — public read, authenticated create/update
    match /social/posts/{postId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null && request.auth.uid == resource.data.uid;
    }

    // Meetups — public read, authenticated RSVP
    match /meetups/{meetupId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
